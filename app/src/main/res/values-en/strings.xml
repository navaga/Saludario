    <string name="onboarding_welcome_title">Welcome to Saludario ❤️</string>
    <string name="onboarding_feature_1_title">Your treatment, under control 💊</string>
    <string name="onboarding_feature_1_body">Medication reminders and daily intake tracking.</string>
    <string name="onboarding_feature_2_title">Your health in detail 📈</string>
    <string name="onboarding_feature_2_body">Track blood pressure, glucose, weight, and other metrics with history and charts.</string>
    <string name="onboarding_feature_3_title">Privacy and control 🔒</string>
    <string name="onboarding_feature_3_body">Your data stays on your device and you can manage it from the app.</string>
    <string name="onboarding_language_future_hint">You can change the language now and update it later from Settings.</string>
    <string name="onboarding_legal_title">Important notice</string>
    <string name="onboarding_legal_body">Saludario is a personal support tool. It does not provide medical advice, diagnosis, or treatment. It does not replace professional healthcare. Always consult a doctor if you have health concerns.</string>
    <string name="onboarding_legal_checkbox">I understand and accept that this app is a support tool and not a medical service.</string>
    <string name="onboarding_legal_privacy_link">Read privacy policy</string>
    <string name="onboarding_notifications_title">Reminders on time</string>
    <string name="onboarding_notifications_body">Saludario lets you know about each dose and when stock starts running low. To do that it needs permission to send notifications.</string>
    <string name="onboarding_notifications_hint">You can change this later from your system settings.</string>
    <string name="onboarding_notifications_allow">Allow notifications</string>
    <string name="onboarding_notifications_skip">Not now</string>
    <string name="onboarding_notifications_granted">Notifications enabled</string>
    <string name="onboarding_notifications_denied">Without notifications, reminders will not be shown automatically.</string>
    <string name="onboarding_reliability_title">Alarm reliability</string>
    <string name="onboarding_reliability_body">Some phones delay or silence alarms to save battery. If you notice that a reminder does not arrive on time, you can fix it from Settings → Reminder reliability.</string>
    <string name="onboarding_reliability_hint">We will warn you in the app if we detect that battery saving may affect your reminders.</string>
    <string name="onboarding_sound_title">Choose how your reminders sound</string>
    <string name="onboarding_sound_body">Keep your device’s default notification sound or pick one of ours. Tap “Preview” to listen before selecting.</string>
    <string name="onboarding_sound_hint">You can change it any time from Settings.</string>
